<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.library.repository.BookRepository">

    <resultMap id="BookResultMap" type="com.example.library.entity.Book">
        <id property="id" column="id"/>
        <result property="isbn" column="isbn"/>
        <result property="title" column="title"/>
        <result property="author" column="author"/>
        <result property="publishedDate" column="published_date"/>
    </resultMap>

    <select id="findAll" resultMap="BookResultMap">
        SELECT id, isbn, title, author, published_date
        FROM books
        ORDER BY id
    </select>

    <select id="findById" resultMap="BookResultMap">
        SELECT id, isbn, title, author, published_date
        FROM books
        WHERE id = #{id}
    </select>

    <select id="findByIsbn" resultMap="BookResultMap">
        SELECT id, isbn, title, author, published_date
        FROM books
        WHERE isbn = #{isbn}
    </select>

    <insert id="insert"
            parameterType="com.example.library.entity.Book"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO books (
            isbn,
            title,
            author,
            published_date
        )
        VALUES (
            #{isbn},
            #{title},
            #{author},
            #{publishedDate}
        )
    </insert>

    <update id="update"
            parameterType="com.example.library.entity.Book">
        UPDATE books
        SET
            isbn = #{isbn},
            title = #{title},
            author = #{author},
            published_date = #{publishedDate}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="long">
        DELETE FROM books
        WHERE id = #{id}
    </delete>

</mapper>